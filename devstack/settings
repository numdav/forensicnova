# ForensicNova DevStack plugin — settings
# Variables are overridable from local.conf.
# Pattern: ${VAR:-default} means "keep VAR if already set, otherwise use default".

# --- Plugin layout ---
FORENSICNOVA_DIR=${FORENSICNOVA_DIR:-$DEST/forensicnova}
FORENSICNOVA_PORT=${FORENSICNOVA_PORT:-5234}
FORENSICNOVA_BIND_HOST=${FORENSICNOVA_BIND_HOST:-0.0.0.0}

# --- Keystone identity artifacts ---
FORENSICNOVA_ROLE=${FORENSICNOVA_ROLE:-forensic_analyst}
FORENSICNOVA_PROJECT=${FORENSICNOVA_PROJECT:-forensics}
FORENSICNOVA_PROJECT_DESCRIPTION=${FORENSICNOVA_PROJECT_DESCRIPTION:-ForensicNova DFIR artifacts and memory acquisition}
FORENSICNOVA_DFIR_USER=${FORENSICNOVA_DFIR_USER:-dfir-tester}
FORENSICNOVA_DFIR_PASSWORD=${FORENSICNOVA_DFIR_PASSWORD:-DFIR-Lab-2026}

# --- Swift storage ---
FORENSICNOVA_SWIFT_CONTAINER=${FORENSICNOVA_SWIFT_CONTAINER:-forensics}

# --- Runtime filesystem layout (on the host) ---
FORENSICNOVA_WORK_DIR=${FORENSICNOVA_WORK_DIR:-/var/lib/forensicnova}
FORENSICNOVA_LOG_DIR=${FORENSICNOVA_LOG_DIR:-/var/log/forensicnova}
FORENSICNOVA_CONF_DIR=${FORENSICNOVA_CONF_DIR:-/etc/forensicnova}
FORENSICNOVA_CONF_FILE=${FORENSICNOVA_CONF_FILE:-$FORENSICNOVA_CONF_DIR/forensicnova.conf}

# --- Generated openrc for testing as dfir-tester ---
FORENSICNOVA_OPENRC=${FORENSICNOVA_OPENRC:-$DEST/devstack/openrc-dfir}

# --- DevStack service registration ---
enable_service forensicnova